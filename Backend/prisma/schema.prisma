datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Simulation {
  id             String   @id @default(uuid())
  circuitType    String
  numFlipFlops   Int
  clockFrequency Float?   @default(1.0)
  inputSequence  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  states         FlipFlopState[]
  timingData     TimingPoint[]
}

model FlipFlopState {
  id               String     @id @default(uuid())
  simulationId     String
  simulation       Simulation @relation(fields: [simulationId], references: [id])
  type             String
  q                Int
  qNot             Int
  nextState        Int?
  propagationDelay Float?
}

model TimingPoint {
  id           String     @id @default(uuid())
  simulationId String
  simulation   Simulation @relation(fields: [simulationId], references: [id])
  cycle        Int
  clock        Int
  input        Int
  outputs      String
  timestamp    DateTime   @default(now())
}

model Challenge {
  id          String   @id @default(uuid())
  title       String
  description String
  difficulty  String
  objective   String
  testCases   String
  hints       String
}

model CircuitPreset {
  id            String   @id @default(uuid())
  name          String
  circuitType   String
  configuration String
  description   String
  learningLevel String
}

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  password    String
  collegeYear String
  course      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects    Project[]
}

model Project {
  id            String   @id @default(uuid())
  userId        String   // Links to User.id (UUID)
  user          User     @relation(fields: [userId], references: [id])
  name          String
  circuitType   String   @default("Shift Register")
  numFlipFlops  Int      @default(4)
  circuitParams Json?     // Simulation parameters object
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  chatMessages  ChatMemory[]
}

model ChatMemory {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  role      String   // "user", "assistant", "system"
  content   String
  createdAt DateTime @default(now())
}
